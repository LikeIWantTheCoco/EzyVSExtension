{
  "name": "ezy-lang",
  "displayName": "Ezy Language",
  "description": "Language server for Ezy (.ez): diagnostics, completion, hover, go-to-definition, signature help, outline, folding, and formatting — \"The clarity of Python, the speed of C\".",
  "version": "0.5.0",
  "publisher": "ezylang",
  "license": "GPL-2.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "ezy",
    "ezylang",
    "ez"
  ],
  "icon": "icons/ezyicon.png",
  "main": "./client.js",
  "activationEvents": [
    "onLanguage:ezy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LikeIWantTheCoco/EzyLang"
  },
  "contributes": {
    "commands": [
      {
        "command": "ezy.run",
        "title": "Ezy: Run File",
        "icon": "$(play)"
      },
      {
        "command": "ezy.compile",
        "title": "Ezy: Compile File",
        "icon": "$(gear)"
      },
      {
        "command": "ezy.format",
        "title": "Ezy: Format File"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "ezy.run",
          "when": "resourceLangId == ezy",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "ezy.run",
          "when": "resourceLangId == ezy",
          "group": "z_ezy@1"
        },
        {
          "command": "ezy.compile",
          "when": "resourceLangId == ezy",
          "group": "z_ezy@2"
        },
        {
          "command": "ezy.format",
          "when": "resourceLangId == ezy",
          "group": "z_ezy@3"
        }
      ],
      "commandPalette": [
        {
          "command": "ezy.run",
          "when": "resourceLangId == ezy"
        },
        {
          "command": "ezy.compile",
          "when": "resourceLangId == ezy"
        },
        {
          "command": "ezy.format",
          "when": "resourceLangId == ezy"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ezy.run",
        "key": "ctrl+f5",
        "when": "resourceLangId == ezy"
      }
    ],
    "configuration": {
      "title": "Ezy",
      "properties": {
        "ezy.path": {
          "type": "string",
          "default": "",
          "description": "Path to the ezy compiler binary. Empty = search ~/.local/bin then PATH."
        },
        "ezy.diagnostics.run": {
          "type": "string",
          "enum": [
            "onType",
            "onSave"
          ],
          "default": "onType",
          "description": "When to run the ezy checker for error highlighting."
        },
        "ezy.diagnostics.undefinedNames": {
          "type": "boolean",
          "default": true,
          "description": "Warn (yellow) when a function or name that has no definition is used."
        }
      }
    },
    "languages": [
      {
        "id": "ezy",
        "aliases": [
          "Ezy",
          "ezy",
          "EzyLang"
        ],
        "extensions": [
          ".ez"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/ezyicon.svg",
          "dark": "./icons/ezyicon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "ezy",
        "scopeName": "source.ezy",
        "path": "./syntaxes/ezy.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ezy",
        "path": "./snippets/ezy.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0",
    "vscode-languageserver": "^8.1.0",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
